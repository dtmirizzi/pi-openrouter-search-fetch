{
  "name": "pi-openrouter-search-fetch",
  "version": "0.1.0",
  "description": "OpenRouter web search & web fetch server tools for Pi — independently toggleable, interactive settings UI",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "author": "dtmirizzi",
  "homepage": "https://github.com/dtmirizzi/pi-openrouter-search-fetch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dtmirizzi/pi-openrouter-search-fetch.git"
  },
  "bugs": {
    "url": "https://github.com/dtmirizzi/pi-openrouter-search-fetch/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "src/index.ts",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "semantic-release": "semantic-release"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "semantic-release": "^24.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/github": "^11.0.1"
  },
  "release": {
    "branches": ["main"],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      ["@semantic-release/git", {
        "assets": ["package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }],
      "@semantic-release/github"
    ]
  }
}
